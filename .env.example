# ============================================
# Yatripati Frontend Configuration
# ============================================
# 
# IMPORTANT SECURITY NOTES:
# 1. NEVER commit .env files with real secrets
# 2. Always use backend proxy for API calls
# 3. API keys should ONLY be stored on backend server
# 4. Environment variables starting with VITE_ are exposed to frontend
#

# ============================================
# API Configuration
# ============================================

# Main API URL (should point to your backend proxy server)
VITE_API_URL=http://localhost:3000/api

# Dashboard API URL (can be same as main API or separate)
VITE_DASHBOARD_API_URL=http://localhost:3000/api

# API Version
VITE_API_VERSION=v1

# Use mock data for development/testing
# Set to 'false' when ready to use real API
VITE_USE_MOCK_DATA=true

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# API Max Retries
VITE_API_MAX_RETRIES=3

# ============================================
# Application Configuration
# ============================================

# Application Name
VITE_APP_NAME=Yatripati News Portal

# Default Author Name
VITE_DEFAULT_AUTHOR=Yatripati

# Site URL (for SEO and social sharing)
VITE_SITE_URL=http://localhost:5173

# Dashboard URL
VITE_DASHBOARD_URL=http://localhost:5174

# ============================================
# Feature Flags
# ============================================

# Enable analytics features
VITE_ENABLE_ANALYTICS=true

# Enable file manager
VITE_ENABLE_FILE_MANAGER=true

# Enable SEO settings
VITE_ENABLE_SEO_SETTINGS=true

# Enable real-time updates
VITE_ENABLE_REALTIME=false

# Enable caching
VITE_ENABLE_CACHING=true

# Cache TTL (minutes)
VITE_CACHE_TTL=5

# ============================================
# Authentication & Security
# ============================================

# Enable authentication
VITE_AUTH_ENABLED=true

# Auth token storage key
VITE_AUTH_TOKEN_KEY=yatripati_auth_token

# Auth user storage key  
VITE_AUTH_USER_KEY=yatripati_user

# Auth refresh token key
VITE_AUTH_REFRESH_KEY=yatripati_refresh_token

# Token expiration (minutes)
VITE_TOKEN_EXPIRY=60

# ============================================
# Development & Debugging
# ============================================

# Enable debug logging
VITE_DEBUG=false

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# Enable error reporting
VITE_ENABLE_ERROR_REPORTING=false

# Error reporting endpoint (if enabled)
# VITE_ERROR_REPORTING_URL=

# ============================================
# Performance & Optimization
# ============================================

# Enable image optimization
VITE_ENABLE_IMAGE_OPTIMIZATION=true

# Lazy loading threshold (pixels)
VITE_LAZY_LOAD_THRESHOLD=200

# Enable service worker
VITE_ENABLE_SERVICE_WORKER=false

# ============================================
# Third-Party Integrations (Placeholders)
# ============================================

# Analytics ID (e.g., Google Analytics)
# VITE_ANALYTICS_ID=

# Social media sharing URLs
# VITE_FACEBOOK_APP_ID=
# VITE_TWITTER_HANDLE=

# ============================================
# DO NOT ADD REAL SECRETS TO THIS FILE
# ============================================
# Never add:
# - API keys
# - Database URLs
# - Passwords
# - Access tokens
# - Private keys
# 
# These belong in:
# - Backend environment variables
# - Secure credential management system (AWS Secrets, HashiCorp Vault, etc.)
