# ============================================
# Yatripati Frontend Configuration
# ============================================
# 
# IMPORTANT SECURITY NOTES:
# 1. NEVER commit .env files with real secrets
# 2. Always use backend proxy for API calls (see BACKEND_PROXY_SETUP.md)
# 3. API keys should ONLY be stored on backend server
# 4. Environment variables starting with VITE_ are exposed to frontend
#

# API Configuration
# This should point to YOUR BACKEND PROXY SERVER, NOT third-party APIs
# The backend proxy will handle actual API calls with secure API keys
VITE_API_URL=http://localhost:3000/api

# For production deployment
# VITE_API_URL=https://yourdomain.com/api

# Use mock data for development/testing
# Set to 'false' when ready to use real API
VITE_USE_MOCK_DATA=true

# API Version (handled by apiClient)
# VITE_API_VERSION=v1

# ============================================
# DO NOT ADD REAL SECRETS TO THIS FILE
# ============================================
# Never add:
# - API keys
# - Database URLs
# - Passwords
# - Access tokens
# - Private keys
# 
# These belong in:
# - Backend environment variables
# - Secure credential management system (AWS Secrets, HashiCorp Vault, etc.)
