# ============================================
# Yatripati Dashboard Configuration
# ============================================
# 
# IMPORTANT: Copy this to .env.local for local development
# Environment variables starting with VITE_ are exposed to frontend
#

# ============================================
# API Configuration
# ============================================

# Dashboard API URL
VITE_DASHBOARD_API_URL=http://localhost:3000/api

# API Version
VITE_API_VERSION=v1

# Use mock data for development/testing
VITE_USE_MOCK_DATA=true

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ============================================
# Application Configuration
# ============================================

# Application Name
VITE_APP_NAME=Yatripati Dashboard

# Dashboard Base Path
VITE_DASHBOARD_BASEPATH=/dashboard

# Default Author Name
VITE_DEFAULT_AUTHOR=Admin

# ============================================
# Feature Flags
# ============================================

# Enable analytics features
VITE_ENABLE_ANALYTICS=true

# Enable file manager
VITE_ENABLE_FILE_MANAGER=true

# Enable SEO settings
VITE_ENABLE_SEO_SETTINGS=true

# Enable real-time updates
VITE_ENABLE_REALTIME=false

# ============================================
# Authentication & Security
# ============================================

# Enable authentication
VITE_AUTH_ENABLED=true

# Auth token storage key
VITE_AUTH_TOKEN_KEY=yatripati_auth_token

# Auth user storage key  
VITE_AUTH_USER_KEY=yatripati_user

# Demo credentials (development only)
VITE_DEMO_EMAIL=admin@yatripati.com
VITE_DEMO_PASSWORD=password

# Auth refresh token storage key
VITE_AUTH_REFRESH_KEY=yatripati_refresh_token

# Token expiry in minutes
VITE_TOKEN_EXPIRY=60

# ============================================
# UI & Performance Configuration
# ============================================

# Default page size for lists
VITE_DEFAULT_PAGE_SIZE=20

# Maximum file upload size in bytes (10MB)
VITE_MAX_UPLOAD_SIZE=10485760

# Auto-refresh interval in milliseconds (30 seconds)
VITE_REFRESH_INTERVAL=30000

# Show onboarding tour
VITE_SHOW_TOUR=true

# Enable caching
VITE_ENABLE_CACHING=true

# Enable error reporting
VITE_ENABLE_ERROR_REPORTING=false

# Enable bulk actions
VITE_ENABLE_BULK_ACTIONS=true

# Enable export features
VITE_ENABLE_EXPORT=true

# Enable import features
VITE_ENABLE_IMPORT=true

# Enable audit log
VITE_ENABLE_AUDIT_LOG=true

# ============================================
# Development & Debugging
# ============================================

# Enable debug logging
VITE_DEBUG=false

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# Error reporting URL (Sentry, etc.)
VITE_ERROR_REPORTING_URL=

# ============================================
# DO NOT ADD REAL SECRETS TO THIS FILE
# ============================================
# Never add:
# - API keys
# - Database URLs
# - Passwords
# - Access tokens
# - Private keys
#
# These belong in backend environment variables
